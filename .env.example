# TheLatest - Environment Variables
# Copy this file to .env and add your API keys
# Never commit .env to git (it's in .gitignore)

# ============================================
# AI SERVICES (for AI Summary feature)
# ============================================

# Choose your preferred AI provider: openai, anthropic, or perplexity
VITE_AI_PROVIDER=perplexity

# OpenAI API Key (for GPT-4) - https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Anthropic API Key exposed to the browser. Avoid in production.
# Leave this empty unless you intentionally want the legacy browser-side path.
# Shared summaries and perspective labeling use server-side ANTHROPIC_API_KEY below.
VITE_ANTHROPIC_API_KEY=

# Perplexity API Key (Recommended) - https://www.perplexity.ai/settings/api
VITE_PERPLEXITY_API_KEY=

# ============================================
# SOCIAL MEDIA APIs
# ============================================

# Twitter/X API Key - https://developer.twitter.com/ ($200/month)
VITE_TWITTER_API_KEY=

# Reddit API - https://www.reddit.com/prefs/apps (FREE)
VITE_REDDIT_CLIENT_ID=
VITE_REDDIT_SECRET=

# YouTube Data API - https://console.cloud.google.com/ (FREE tier)
VITE_YOUTUBE_API_KEY=

# Instagram Graph API - https://developers.facebook.com/
VITE_INSTAGRAM_API_KEY=

# ============================================
# NEWS APIs
# ============================================

NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_key_here

# RSSHub base URL for social feed route resolution
RSSHUB_BASE_URL=https://rsshub.app

# ============================================
# AUTH / ADMIN
# ============================================

# Strong random string used to hash session tokens before persistence.
SESSION_TOKEN_PEPPER=

# Optional allowlist for dashboard/admin-only function actions.
# Comma-separated email list.
ADMIN_EMAILS=

# ============================================
# NETLIFY BLOBS
# ============================================

# Netlify production injects Blob access automatically.
# For local Netlify dev, Docker, CI, or direct Node handler checks,
# set both values below if you want shared summaries, snapshots, and
# feed health to persist instead of falling back to ephemeral memory.
NETLIFY_BLOBS_SITE_ID=
NETLIFY_BLOBS_TOKEN=

# ============================================
# OPTIONAL FUNCTION TUNING
# ============================================

RSS_APP_BUNDLE_FEED_URL=
RSS_APP_BUNDLE_SOURCE=The Latest Bundle
SOCIAL_RSS_FEEDS=
# Primary Anthropic secret used by Netlify functions such as sharedSummary and perspective.
# Set this in your local root .env for local dev and in the Netlify UI for hosted environments.
# Do not prefix with VITE_ or it will be exposed to the browser bundle.
ANTHROPIC_API_KEY=
ANTHROPIC_SUMMARY_MODEL=claude-sonnet-5
ANTHROPIC_PERSPECTIVE_MODEL=claude-haiku-4-5

