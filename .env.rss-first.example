# Minimal local env for an RSS-first setup.
# Copy to .env when you want a low-friction local or Docker run.

# Required for auth/session hashing.
SESSION_TOKEN_PEPPER=replace-with-a-long-random-string

# Use the built-in editorial summary path instead of paid AI providers.
VITE_AI_PROVIDER=editorial

# Keep RSSHub explicit for social route resolution.
RSSHUB_BASE_URL=https://rsshub.app

# Leave these unset to use the built-in bundle defaults plus all configured feeds
# already defined in netlify/functions/rss-aggregator.js.
# RSS_APP_BUNDLE_FEED_URL=
# RSS_APP_BUNDLE_SOURCE=The Latest Bundle

# Optional only if you want to override social feed rotation from env.
# SOCIAL_RSS_FEEDS=

# Optional only if you want local Blob persistence instead of graceful fallback.
# NETLIFY_BLOBS_SITE_ID=
# NETLIFY_BLOBS_TOKEN=