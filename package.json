{
  "name": "thelatest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "vite",
    "dev:netlify": "node scripts/dev-netlify.mjs",
    "build": "node scripts/generate-sitemap.mjs && vite build",
    "verify:deploy-env": "node scripts/verify-deploy-env.mjs",
    "verify:deploy-env:strict": "node scripts/verify-deploy-env.mjs --strict",
    "verify:deploy-env:blobs": "node scripts/verify-deploy-env.mjs --require-blobs",
    "smoke:netlify-preview": "node scripts/smoke-netlify-preview.mjs",
    "lint": "eslint .",
